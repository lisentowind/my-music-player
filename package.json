{
  "name": "my-player-desktop-starter",
  "description": "Tauri + Vue 3 + TypeScript desktop starter",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "tauri:dev": "tauri dev",
    "build": "tauri build",
    "build:web": "vue-tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm typecheck:web && pnpm typecheck:node",
    "typecheck:web": "vue-tsc --noEmit",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "format": "prettier . --write",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@iconify-icons/solar": "^1.2.2",
    "@iconify/vue": "^5.0.0",
    "@tauri-apps/api": "^2",
    "gsap": "^3.13.0",
    "howler": "^2.2.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/node": "^24.6.1",
    "@tauri-apps/cli": "^2",
    "@unocss/preset-attributify": "^66.6.7",
    "@unocss/preset-uno": "^66.6.7",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "happy-dom": "^20.0.10",
    "less": "^4.6.4",
    "prettier": "^3.8.1",
    "typescript": "~5.6.2",
    "unocss": "^66.6.7",
    "vite": "^6.0.3",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.1.10"
  }
}
